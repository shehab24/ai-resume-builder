generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  JOB_SEEKER
  RECRUITER
  ADMIN
}

enum RecruiterStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId           String   @unique
  email             String   @unique
  name              String?
  country           String?
  photoUrl          String?
  autoApply         Boolean  @default(false)
  matchThreshold    Int      @default(95) // Minimum match percentage for job matching (0-100)
  autoApplyCountry  String?  // Country filter for auto-apply feature
  role              Role     @default(JOB_SEEKER)
  
  // Recruiter Verification
  recruiterStatus   RecruiterStatus @default(NONE)
  companyInfo       Json?           // Stores { companyName, website, size, description, etc. }
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastSeenAt        DateTime? // Updated on every authenticated page visit

  // Moderation
  isBlocked         Boolean  @default(false)
  blockedUntil      DateTime?
  warningCount      Int      @default(0)

  // Job Seeker relations
  resumes      Resume[]
  applications Application[]

  // Recruiter relations
  // Recruiter relations
  postedJobs Job[]
  
  notifications Notification[]
  interviewParticipations InterviewParticipant[]
  
  // Payment relations
  subscriptions Subscription[]
  payments      Payment[]
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // "APPLICATION_RECEIVED", "STATUS_UPDATE", "TASK_ASSIGNED"
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Resume {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String // JSON string or structured data
  pdfUrl    String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  applications Application[]
}

model Job {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  recruiterId      String   @db.ObjectId
  recruiter        User     @relation(fields: [recruiterId], references: [id])
  
  // Basic Info
  title            String
  description      String
  requirements     String[]
  
  // Professional Fields
  company          String?
  location         String?
  country          String? // Added country field for better matching
  jobType          String?  // Full-time, Part-time, Contract, Internship
  workMode         String?  // Remote, Hybrid, On-site
  experienceLevel  String?  // Entry, Mid, Senior, Lead
  
  // Compensation
  salary           String?  // Display text like "$100k - $150k"
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String?  @default("USD")
  
  // Additional Details
  benefits         String[] // Health insurance, 401k, etc.
  applicationDeadline DateTime?
  
  // Tasks for applicants
  tasks            String[] // Array of task descriptions
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // External Job Fields
  isExternal       Boolean  @default(false) // True if scraped from external source
  externalUrl      String?  // Original job posting URL
  externalId       String?  // ID from external source
  sourceId         String?  @db.ObjectId // Reference to JobSource
  source           JobSource? @relation(fields: [sourceId], references: [id])
  
  // Application Method
  applicationMethod String  @default("INTERNAL") // INTERNAL, EXTERNAL_LINK, EMAIL
  applicationEmail  String? // If application is via email
  
  applications     Application[]
}

// Track external job sources
model JobSource {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // e.g., "LinkedIn", "Indeed", "Company Website"
  url         String   // Base URL of the source
  description String?
  isActive    Boolean  @default(true)
  
  // Scraping config (for future automation)
  scrapingEnabled Boolean @default(false)
  lastScrapedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  jobs        Job[]
}

model Application {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  jobId            String   @db.ObjectId
  status           String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  taskSubmissions  Json[]   @default([])
  
  // AI Scoring Fields
  resumeScore      Int?     // 0-100: How well resume matches job requirements
  taskScore        Int?     // 0-100: AI evaluation of task submissions
  compositeScore   Int?     // 0-100: Weighted average (40% resume + 60% task)
  aiEvaluation     String?  // AI's detailed feedback on candidate
  resumeId         String?  @db.ObjectId // Reference to the selected resume
  resume           Resume?  @relation(fields: [resumeId], references: [id])
  resumeContent    Json?    // Snapshot of resume content at time of application
  isTopCandidate   Boolean  @default(false) // Auto-set for top 10 candidates
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])
  
  interviews Interview[]

  @@index([userId])
  @@index([jobId])
  @@index([compositeScore])
}

enum InterviewStatus {
  SCHEDULED
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Interview {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  applicationId   String          @db.ObjectId
  application     Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  scheduledAt     DateTime
  duration        Int             @default(60) // Duration in minutes
  status          InterviewStatus @default(SCHEDULED)
  
  // Stream Video Call Details
  streamCallId    String          @unique
  
  // Join tracking
  recruiterJoined Boolean         @default(false)
  seekerJoined    Boolean         @default(false)
  
  // Notes and feedback
  recruiterNotes  String?
  seekerNotes     String?
  
  // Structured Interview Notes (shared between both parties)
  interviewMarks  Int?            // Overall rating out of 10
  technicalMarks  Int?            // Technical skills rating out of 10
  behavioralMarks Int?            // Behavioral/soft skills rating out of 10
  salaryDiscussed String?         // Salary expectations discussed
  benefits        String?         // Benefits discussed
  startDate       String?         // Possible start date
  keyTopics       String[]        @default([]) // Important topics discussed
  interviewNotes  String?         // General notes from the interview
  
  // Recording
  recordingUrl    String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([applicationId])
  @@index([scheduledAt])
  @@index([status])
  
  participants    InterviewParticipant[]
}

model InterviewParticipant {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  interviewId     String    @db.ObjectId
  userId          String
  role            String    // "PRIMARY_RECRUITER" | "PANEL_RECRUITER" | "CANDIDATE"
  joinedAt        DateTime?
  createdAt       DateTime  @default(now())
  
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([interviewId, userId])
  @@index([userId])
  @@index([interviewId])
}

model Subscription {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  plan            String   // "FREE" | "PRO" | "ENTERPRISE"
  planType        String?  // "JOB_SEEKER_PRO" (299) | "RECRUITER_PRO" (999) | "ALL_FEATURES_PRO" (999)
  status          String   // "ACTIVE" | "CANCELLED" | "EXPIRED"
  amount          Float
  currency        String   @default("BDT")
  startDate       DateTime @default(now())
  endDate         DateTime
  autoRenew       Boolean  @default(true)
  
  user            User     @relation(fields: [userId], references: [id])
  payments        Payment[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payment {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  subscriptionId    String?  @db.ObjectId
  
  // SSLCommerz fields
  transactionId     String   @unique  // tran_id
  amount            Float
  currency          String   @default("BDT")
  status            String   // "PENDING" | "SUCCESS" | "FAILED" | "CANCELLED"
  paymentMethod     String?  // "card" | "bkash" | "rocket" etc.
  
  // SSLCommerz response
  bankTransactionId String?  // bank_tran_id
  cardType          String?
  cardIssuer        String?
  validationId      String?  // val_id
  
  // Metadata
  description       String?
  planType          String?  // "JOB_SEEKER_PRO" | "RECRUITER_PRO" | "ALL_FEATURES_PRO"
  failureReason     String?
  
  user              User         @relation(fields: [userId], references: [id])
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String   // Email or Phone
  token      String
  expires    DateTime
  createdAt  DateTime @default(now())
  
  @@unique([identifier, token])
}
