generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  JOB_SEEKER
  RECRUITER
  ADMIN
}

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId           String   @unique
  email             String   @unique
  name              String?
  country           String?
  photoUrl          String?
  autoApply         Boolean  @default(false)
  matchThreshold    Int      @default(95) // Minimum match percentage for job matching (0-100)
  autoApplyCountry  String?  // Country filter for auto-apply feature
  role              Role     @default(JOB_SEEKER)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Moderation
  isBlocked         Boolean  @default(false)
  blockedUntil      DateTime?
  warningCount      Int      @default(0)

  // Job Seeker relations
  resumes      Resume[]
  applications Application[]

  // Recruiter relations
  // Recruiter relations
  postedJobs Job[]
  
  notifications Notification[]
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // "APPLICATION_RECEIVED", "STATUS_UPDATE", "TASK_ASSIGNED"
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Resume {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String // JSON string or structured data
  pdfUrl    String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  recruiterId      String   @db.ObjectId
  recruiter        User     @relation(fields: [recruiterId], references: [id])
  
  // Basic Info
  title            String
  description      String
  requirements     String[]
  
  // Professional Fields
  company          String?
  location         String?
  country          String? // Added country field for better matching
  jobType          String?  // Full-time, Part-time, Contract, Internship
  workMode         String?  // Remote, Hybrid, On-site
  experienceLevel  String?  // Entry, Mid, Senior, Lead
  
  // Compensation
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String?  @default("USD")
  
  // Additional Details
  benefits         String[] // Health insurance, 401k, etc.
  applicationDeadline DateTime?
  
  // Tasks for applicants
  tasks            String[] // Array of task descriptions
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // External Job Fields
  isExternal       Boolean  @default(false) // True if scraped from external source
  externalUrl      String?  // Original job posting URL
  externalId       String?  // ID from external source
  sourceId         String?  @db.ObjectId // Reference to JobSource
  source           JobSource? @relation(fields: [sourceId], references: [id])
  
  // Application Method
  applicationMethod String  @default("INTERNAL") // INTERNAL, EXTERNAL_LINK, EMAIL
  applicationEmail  String? // If application is via email
  
  applications     Application[]
}

// Track external job sources
model JobSource {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // e.g., "LinkedIn", "Indeed", "Company Website"
  url         String   // Base URL of the source
  description String?
  isActive    Boolean  @default(true)
  
  // Scraping config (for future automation)
  scrapingEnabled Boolean @default(false)
  lastScrapedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  jobs        Job[]
}

model Application {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  jobId            String   @db.ObjectId
  status           String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  taskSubmissions  Json[]   @default([])
  
  // AI Scoring Fields
  resumeScore      Int?     // 0-100: How well resume matches job requirements
  taskScore        Int?     // 0-100: AI evaluation of task submissions
  compositeScore   Int?     // 0-100: Weighted average (40% resume + 60% task)
  aiEvaluation     String?  // AI's detailed feedback on candidate
  isTopCandidate   Boolean  @default(false) // Auto-set for top 10 candidates
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  @@index([userId])
  @@index([jobId])
  @@index([compositeScore])
}
